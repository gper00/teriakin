<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".MainActivity">

    <!-- HOME SCREEN -->
    <LinearLayout
        android:id="@+id/homeScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/timer_title"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:letterSpacing="0.25" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="monospace"
            android:text="25:00"
            android:textColor="@color/text_primary"
            android:textSize="72sp"
            android:textStyle="bold" />

        <!-- Preset chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/chip5min"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:background="@drawable/chip_bg"
                android:text="@string/preset_5m"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip15min"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:background="@drawable/chip_bg"
                android:text="@string/preset_15m"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip25min"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:background="@drawable/chip_bg_selected"
                android:text="@string/preset_25m"
                android:textColor="@color/bg_primary"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/chip45min"
                android:layout_width="48dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:background="@drawable/chip_bg"
                android:text="@string/preset_45m"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="40dp"
            android:backgroundTint="@color/primary_green"
            android:text="@string/btn_start"
            android:textColor="@color/bg_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="28dp" />

        <!-- Bottom nav -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnSetup"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="⚙"
                android:textSize="22sp"
                android:background="@drawable/chip_bg"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="36dp"
                android:gravity="center"
                android:text="📊"
                android:textSize="20sp"
                android:background="@drawable/chip_bg"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- TIMER RUNNING OVERLAY -->
    <LinearLayout
        android:id="@+id/timerOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:paddingHorizontal="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvOverlayTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="25:00"
            android:textColor="@color/text_primary"
            android:textSize="72sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressTimer"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="24dp"
            android:progressTint="@color/primary_green"
            android:progressBackgroundTint="@color/bg_surface" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnPauseOverlay"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="140dp"
                android:layout_height="52dp"
                android:text="@string/btn_pause"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                app:cornerRadius="26dp"
                app:strokeColor="@color/text_secondary" />

            <Button
                android:id="@+id/btnStopOverlay"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="140dp"
                android:layout_height="52dp"
                android:layout_marginStart="16dp"
                android:text="@string/btn_stop"
                android:textColor="@color/danger_red"
                android:textSize="15sp"
                app:cornerRadius="26dp"
                app:strokeColor="@color/danger_red" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDistractionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="📱 0 distractions"
            android:textColor="@color/text_muted"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- SETUP SCREEN (included in Task 8) -->
    <LinearLayout
        android:id="@+id/setupScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBackSetup"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/chip_bg" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/setup_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View android:layout_width="48dp" android:layout_height="1dp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/setup_apps"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Select apps that distract you"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/editSearchApps"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:hint="Search apps..."
            android:background="@drawable/bg_input"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvApps"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/setup_alarm"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioAlarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/radioBuiltin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_alarm_builtin"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_green" />

            <RadioButton
                android:id="@+id/radioFile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_alarm_file"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_green" />

            <RadioButton
                android:id="@+id/radioRecord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_alarm_record"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_green" />

        </RadioGroup>

        <Button
            android:id="@+id/btnPreviewAlarm"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:text="@string/setup_preview"
            android:backgroundTint="@color/bg_surface"
            android:textColor="@color/text_primary"
            app:cornerRadius="24dp" />

        <Button
            android:id="@+id/btnSaveSetup"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="@string/setup_save"
            android:backgroundTint="@color/primary_green"
            android:textColor="@color/bg_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="26dp" />

    </LinearLayout>

    <!-- HISTORY SCREEN (included in Task 8) -->
    <LinearLayout
        android:id="@+id/historyScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_primary"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/btnBackHistory"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="←"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/chip_bg" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/history_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View android:layout_width="48dp" android:layout_height="1dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvHistoryEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/history_empty"
            android:textColor="@color/text_muted"
            android:textSize="16sp"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
